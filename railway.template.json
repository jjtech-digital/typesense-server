{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "Typesense Server",
  "description": "Typesense search engine with Caddy reverse proxy — one-click deploy on Railway.",
  "icon": "https://typesense.org/favicon.png",
  "services": [
    {
      "name": "typesense",
      "source": {
        "repo": "jjtech-digital/typesense-server",
        "branch": "main"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile",
        "watchPatterns": ["Dockerfile", "Caddyfile", "scripts/*"]
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5,
        "drainingSeconds": 30
      },
      "networking": {
        "servicePort": 8080
      },
      "variables": {
        "PORT": {
          "description": "Public-facing port (auto-assigned by Railway)",
          "default": "8080",
          "required": true
        },
        "TYPESENSE_API_KEY": {
          "description": "API key for authenticating requests to Typesense",
          "generate": true,
          "required": true
        },
        "TYPESENSE_DATA_DIR": {
          "description": "Directory for persistent data storage (Railway volume mount path)",
          "default": "${{RAILWAY_VOLUME_MOUNT_PATH}}",
          "required": true
        },
        "TYPESENSE_NUM_COLLECTIONS_PARALLEL_LOAD": {
          "description": "Number of collections to load in parallel at startup",
          "default": "32",
          "required": false
        },
        "TYPESENSE_PUBLIC_URL": {
          "description": "Public URL for the Typesense instance",
          "default": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
          "required": false
        },
        "TYPESENSE_THREAD_POOL_SIZE": {
          "description": "Number of threads in the Typesense thread pool",
          "default": "64",
          "required": false
        },
        "TYPESENSE_URL": {
          "description": "Internal URL for service-to-service communication within Railway",
          "default": "http://${{RAILWAY_PRIVATE_DOMAIN}}:${{PORT}}",
          "required": false
        }
      },
      "volumes": [
        {
          "mountPath": "/data",
          "name": "typesense-data"
        }
      ]
    }
  ]
}
